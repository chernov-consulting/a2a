# env.yaml.example — copy to env.yaml and fill in values.
# API keys belong in .env (never committed).
# This file controls simulation behaviour and model routing.

app:
  log_level: INFO
  debug: false

models:
  # Default model for the buyer agent
  buyer_model: openai/gpt-4o
  # Default model for the seller agent
  seller_model: anthropic/claude-3-5-sonnet-20241022
  # Model used as the independent judge for rationale scoring
  judge_model: openai/gpt-4o-mini
  # Maximum tokens per LLM call
  max_tokens: 4096
  # Temperature — keep low for deterministic reasoning
  temperature: 0.2

simulation:
  # Random seed for reproducibility (override per-experiment in config.yaml)
  seed: 42
  # Number of dyads per cell (buyer archetype × seller variant)
  dyads_per_cell: 30
  # Maximum negotiation turns before auto-close (no-deal)
  max_negotiation_turns: 3
  # Autonomy dial: full_auto | checkpoint_at_decision | audit_each_step
  autonomy: full_auto

catalog:
  # Timeout in seconds for fetching product URLs
  fetch_timeout_s: 30
  # Maximum PDF pages to process
  max_pdf_pages: 20

reporting:
  # Open the HTML report in the browser after generation
  auto_open: false
