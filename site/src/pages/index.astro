---
import Base from '../layouts/Base.astro';

const protocols = [
  { name: 'AP2', layer: 'Authorization', desc: 'Cryptographically signed mandates. Know Your Agent.', link: 'https://github.com/chernov-consulting/a2a/tree/main/src/a2a/protocols/ap2' },
  { name: 'MCP', layer: 'Intent', desc: 'Model Context Protocol. The catalog becomes a tool manifest.', link: 'https://github.com/chernov-consulting/a2a/tree/main/src/a2a/protocols/mcp' },
  { name: 'A2A', layer: 'Intent', desc: 'Agent-to-Agent Protocol. Interoperability across vendors.', link: 'https://github.com/chernov-consulting/a2a/tree/main/src/a2a/protocols/a2a_proto' },
  { name: 'x402', layer: 'Intent + Auth', desc: 'HTTP 402 in-band payments. No checkout flow.', link: 'https://github.com/chernov-consulting/a2a/tree/main/src/a2a/protocols/x402' },
  { name: 'UCP', layer: 'Intent', desc: 'Google Universal Commerce Protocol. GEO made concrete.', link: 'https://github.com/chernov-consulting/a2a/tree/main/src/a2a/protocols/ucp' },
];

const questions = [
  {
    num: '01',
    q: 'How should a buyer agent assemble its context?',
    detail: 'We test three mandate richness levels — terse JSON, annotated brief, full conversation transcript — against conversion rate and rationale quality.',
    accent: 'text-accent',
  },
  {
    num: '02',
    q: 'What does onboarding look like for an agent audience?',
    detail: 'Three seller funnel variants: API contract, rich schema, persuasion page. Does the 70-screen onboarding flow backfire when your customer is an algorithm?',
    accent: 'text-accent-green',
  },
  {
    num: '03',
    q: 'Can agents explain why a transaction happened?',
    detail: 'Both agents emit a structured rationale. An independent judge LLM scores citation quality, mandate alignment, and counterfactual strength.',
    accent: 'text-accent-amber',
  },
];
---
<Base>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="font-mono text-sm font-medium tracking-tight">a2a.chernov.io</a>
      <div class="flex gap-6 text-sm text-neutral-400">
        <a href="#questions" class="hover:text-neutral-100 transition">Questions</a>
        <a href="#experiments" class="hover:text-neutral-100 transition">Experiments</a>
        <a href="#protocols" class="hover:text-neutral-100 transition">Protocols</a>
        <a href="https://github.com/chernov-consulting/a2a" class="hover:text-neutral-100 transition">GitHub</a>
        <a href="https://chernov.io/writing/when-both-sides-are-agents/" class="text-accent hover:text-indigo-300 transition">Article →</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="min-h-screen flex flex-col justify-center pt-20 pb-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="inline-block font-mono text-xs text-neutral-500 border border-neutral-800 rounded px-2 py-1 mb-8">
        v0.1 · open benchmark · Apache-2.0 / CC-BY-4.0
      </div>

      <h1 class="text-5xl sm:text-7xl font-bold tracking-tight leading-none mb-6">
        When Both<br />
        <span class="text-accent">Sides</span> Are<br />
        Agents.
      </h1>

      <p class="text-xl text-neutral-400 max-w-2xl mb-10 leading-relaxed">
        E-commerce funnels were built for human psychology. What happens when the buyer
        <em>and</em> the seller are AI agents? We ran the experiment.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="https://chernov.io/writing/when-both-sides-are-agents/"
          class="px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-indigo-400 transition"
        >
          Read the article
        </a>
        <a
          href="https://github.com/chernov-consulting/a2a"
          class="px-6 py-3 border border-neutral-700 text-neutral-300 font-semibold rounded-lg hover:border-neutral-500 hover:text-white transition"
        >
          View on GitHub
        </a>
      </div>

      <!-- Live stats placeholder — populated from experiment data post-run -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-16">
        <div class="border border-neutral-800 rounded-xl p-5">
          <div class="text-neutral-500 text-xs mb-1 font-mono">dyads simulated</div>
          <div class="text-3xl font-bold">540</div>
          <div class="text-neutral-500 text-xs mt-1">per product</div>
        </div>
        <div class="border border-neutral-800 rounded-xl p-5">
          <div class="text-neutral-500 text-xs mb-1 font-mono">cell matrix</div>
          <div class="text-3xl font-bold">3×3</div>
          <div class="text-neutral-500 text-xs mt-1">archetype × funnel</div>
        </div>
        <div class="border border-neutral-800 rounded-xl p-5">
          <div class="text-neutral-500 text-xs mb-1 font-mono">protocols coded</div>
          <div class="text-3xl font-bold text-accent-green">5</div>
          <div class="text-neutral-500 text-xs mt-1">AP2, MCP, A2A, x402, UCP</div>
        </div>
        <div class="border border-neutral-800 rounded-xl p-5">
          <div class="text-neutral-500 text-xs mb-1 font-mono">layer 3</div>
          <div class="text-3xl font-bold text-accent-amber">mocked</div>
          <div class="text-neutral-500 text-xs mt-1">no real money</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three questions -->
  <section id="questions" class="py-24 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto">
      <div class="font-mono text-xs text-neutral-500 mb-4">research questions</div>
      <h2 class="text-3xl font-bold mb-16">Three questions this experiment answers.</h2>
      <div class="space-y-12">
        {questions.map(q => (
          <div class="grid grid-cols-1 md:grid-cols-[60px_1fr] gap-6 items-start">
            <div class={`font-mono text-4xl font-bold ${q.accent} opacity-60`}>{q.num}</div>
            <div>
              <h3 class="text-xl font-semibold mb-2">{q.q}</h3>
              <p class="text-neutral-400 leading-relaxed">{q.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pipeline diagram -->
  <section class="py-24 px-6 border-t border-neutral-800 bg-neutral-900/30">
    <div class="max-w-5xl mx-auto">
      <div class="font-mono text-xs text-neutral-500 mb-4">how it works</div>
      <h2 class="text-3xl font-bold mb-12">The simulation pipeline.</h2>
      <div class="font-mono text-sm overflow-x-auto">
        <pre class="text-neutral-300 leading-relaxed">{`
  product URL / PDF / text
         │
         ▼
  Catalog fetcher  ──────────►  Seller agent
  (structured schema)           (funnel variant:
         │                       api_contract |
         │                       rich_schema  |
         ▼                       persuasion_page)
  Buyer agent                         │
  (archetype:                         │
   price_optimiser |                  │
   feature_matcher |   ◄──────────────┘
   risk_averse)        A2A negotiation (≤3 turns)
         │
         ▼
  Decision: buy | walk | escalate | timeout
         │
         ▼
  L3 mock settlement  ←── no real money, ever
         │
         ▼
  JSONL ledger  ──►  HTML report  ──►  this site
  (tokens, latency,
   cost, rationales,
   judge scores)`}
        </pre>
      </div>
    </div>
  </section>

  <!-- Experiments -->
  <section id="experiments" class="py-24 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto">
      <div class="font-mono text-xs text-neutral-500 mb-4">experiments</div>
      <h2 class="text-3xl font-bold mb-4">Two product categories. Same methodology.</h2>
      <p class="text-neutral-400 mb-12">
        Contrasting a B2B SaaS subscription (rational, feature-driven) with a physical goods subscription
        (emotional, trust-driven) surfaces how much product type affects agent behaviour.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-neutral-800 rounded-xl p-6">
          <div class="font-mono text-xs text-neutral-500 mb-3">2026-05-saas-subscription</div>
          <h3 class="text-lg font-semibold mb-2">ObserveOps Pro</h3>
          <p class="text-neutral-400 text-sm mb-4">
            B2B SaaS observability platform. Metrics, logs, traces, AI anomaly detection.
            Pricing: $49–$299/month + Enterprise. SOC 2 Type II.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">saas</span>
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">b2b</span>
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">subscription</span>
          </div>
          <div class="mt-4 pt-4 border-t border-neutral-800">
            <a href="https://github.com/chernov-consulting/a2a/tree/main/experiments/2026-05-saas-subscription" class="text-accent text-sm hover:underline">
              View experiment config →
            </a>
          </div>
        </div>
        <div class="border border-neutral-800 rounded-xl p-6">
          <div class="font-mono text-xs text-neutral-500 mb-3">2026-05-physical-good</div>
          <h3 class="text-lg font-semibold mb-2">Terroir Direct</h3>
          <p class="text-neutral-400 text-sm mb-4">
            Monthly single-bottle wine subscription from independent European vineyards.
            Pricing: $35–$75/month. B Corporation certified. 4.9/5 Trustpilot.
          </p>
          <div class="flex gap-2 flex-wrap">
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">physical</span>
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">b2c</span>
            <span class="font-mono text-xs bg-neutral-800 px-2 py-1 rounded">subscription</span>
          </div>
          <div class="mt-4 pt-4 border-t border-neutral-800">
            <a href="https://github.com/chernov-consulting/a2a/tree/main/experiments/2026-05-physical-good" class="text-accent text-sm hover:underline">
              View experiment config →
            </a>
          </div>
        </div>
      </div>
      <div class="mt-8 p-6 border border-neutral-800 rounded-xl bg-neutral-900/50">
        <div class="font-mono text-xs text-accent mb-2">run it yourself</div>
        <pre class="text-sm text-neutral-300 overflow-x-auto">{`git clone https://github.com/chernov-consulting/a2a && cd a2a
cp env.yaml.example env.yaml && cp .env.example .env
# add your API keys to .env
uv sync && uv run a2a sim --experiment experiments/2026-05-saas-subscription/config.yaml
uv run a2a report --experiment experiments/2026-05-saas-subscription/`}</pre>
      </div>
    </div>
  </section>

  <!-- Protocol comparison -->
  <section id="protocols" class="py-24 px-6 border-t border-neutral-800 bg-neutral-900/30">
    <div class="max-w-5xl mx-auto">
      <div class="font-mono text-xs text-neutral-500 mb-4">payment protocols</div>
      <h2 class="text-3xl font-bold mb-4">Five open standards. Versioned, runnable code.</h2>
      <p class="text-neutral-400 mb-12">
        Each protocol sample runs the same toy transaction and emits a standard JSONL ledger record —
        so you can compare latency, steps, and trust model side-by-side.
        <a href="https://chernov.io/writing/when-both-sides-are-agents/" class="text-accent hover:underline ml-1">
          Read the full comparison in the article →
        </a>
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-800 text-neutral-400 text-xs font-mono">
              <th class="text-left py-3 pr-6">Protocol</th>
              <th class="text-left py-3 pr-6">IMF Layer</th>
              <th class="text-left py-3 pr-6">Description</th>
              <th class="text-left py-3">Code</th>
            </tr>
          </thead>
          <tbody>
            {protocols.map(p => (
              <tr class="border-b border-neutral-800/50 hover:bg-neutral-900/50 transition">
                <td class="py-4 pr-6 font-mono font-medium">{p.name}</td>
                <td class="py-4 pr-6 text-neutral-400 font-mono text-xs">{p.layer}</td>
                <td class="py-4 pr-6 text-neutral-300">{p.desc}</td>
                <td class="py-4">
                  <a href={p.link} class="text-accent text-xs hover:underline font-mono">bench.py →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 text-neutral-500 text-xs font-mono">
        Deferred to v0.2: Visa Intelligent Commerce · Mastercard Agent Suite · OpenAI/Stripe Instant Checkout · PayPal Cymbio · Stripe tokenized authorization
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">The full story is in the article.</h2>
      <p class="text-neutral-400 mb-8 max-w-xl mx-auto">
        Theory, data, protocol comparison, and what it means for anyone building merchant-facing products today.
      </p>
      <a
        href="https://chernov.io/writing/when-both-sides-are-agents/"
        class="inline-block px-8 py-4 bg-accent text-white font-semibold rounded-lg hover:bg-indigo-400 transition text-lg"
      >
        Read "When Both Sides Are Agents"
      </a>
    </div>
  </section>
</Base>
